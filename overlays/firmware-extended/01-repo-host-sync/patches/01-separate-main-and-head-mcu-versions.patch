+get_expected_mcu_version()
+{
+	mcu=$1
+
+	case $mcu in
+		mcu0)
+			version_file="$MAIN_MCU_FIRMWARE_VERSION_FILE"
+			;;
+		head0|head1|head2|head3)
+			version_file="$HEAD_MCU_FIRMWARE_VERSION_FILE"
+			;;
+		*)
+			version_file="$LEGACY_MCU_FIRMWARE_VERSION_FILE"
+			;;
+	esac
+
+	if [ -f "$version_file" ] ; then
+		cat "$version_file"
+	elif [ -f "$LEGACY_MCU_FIRMWARE_VERSION_FILE" ] ; then
+		cat "$LEGACY_MCU_FIRMWARE_VERSION_FILE"
+	else
+		echo "unknown"
+	fi
